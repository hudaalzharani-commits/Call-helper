# نسخ إلى .env للتطوير المحلي (لا ترفع .env إلى GitHub)

# عنوان API — محلياً اتركه فارغاً (يستخدم بروكسي Vite على /api)
# VITE_API_BASE_URL=

# إنتاج (Cloudflare Pages — Build variables):
# VITE_API_BASE_URL=https://YOUR-APP.up.railway.app/api

# تفعيل ميزات AI في الواجهة (اختياري)
VITE_ENABLE_AI=false
