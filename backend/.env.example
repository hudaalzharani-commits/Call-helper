# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# MongoDB Connection
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/rafeeq_db

# Or MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/rafeeq_db?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# AI Service Configuration
# Choose one: OpenAI or Anthropic Claude
# Leave both empty to use mock responses for development

# OpenAI Configuration (Recommended)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
# Alternative models: gpt-4-turbo, gpt-3.5-turbo

# Anthropic Claude Configuration (Alternative)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229
# Alternative models: claude-3-opus-20240229, claude-3-haiku-20240307
